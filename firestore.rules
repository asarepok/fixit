rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function unchanged(field) {
      return request.resource.data[field] == resource.data[field];
    }

    // ---- users ----
    // Any signed-in user can read a profile (needed to show artisan names,
    // ratings, etc.). A user can edit their own name/phone/location/
    // profession/bio freely. role and the rating aggregates are never
    // client-writable, only an admin (or, for ratings, the submitReview
    // Cloud Function via the Admin SDK) can change those. artisanStatus is
    // a one-way exception: a user may flip their own from "none" to
    // "pending" (that's what submitting a Become an Artisan application
    // is), anything past that (to "verified"/"rejected") is admin-only.
    function isSubmittingArtisanApplication() {
      return (!('artisanStatus' in resource.data) || resource.data.artisanStatus == 'none')
        && request.resource.data.artisanStatus == 'pending';
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSelf(uid);
      allow update: if isAdmin() || (
        isSelf(uid) &&
        unchanged('role') &&
        unchanged('averageRating') &&
        unchanged('ratingCount') &&
        unchanged('balance') &&
        (unchanged('artisanStatus') || isSubmittingArtisanApplication())
      );
      allow delete: if false;
    }

    // ---- bookings ----
    // A customer can only read/cancel their own bookings, an artisan only
    // their own assigned bookings, admins see everything. paymentStatus is
    // Cloud-Function-only (set from the Admin SDK after a Paystack
    // webhook), never client-writable.
    match /bookings/{bookingId} {
      allow read: if isSignedIn() &&
        (resource.data.customerId == request.auth.uid ||
         resource.data.artisanId == request.auth.uid ||
         isAdmin());

      allow create: if isSignedIn() &&
        request.resource.data.customerId == request.auth.uid &&
        request.resource.data.customerId != request.resource.data.artisanId &&
        request.resource.data.status == 'pending';

      allow update: if isSignedIn() && unchanged('paymentStatus') && (
        (resource.data.customerId == request.auth.uid && (
          (resource.data.status == 'pending' && request.resource.data.status == 'cancelled') ||
          (unchanged('status') && unchanged('artisanId') && unchanged('description') &&
           unchanged('location') && unchanged('amount'))
        )) ||
        (resource.data.artisanId == request.auth.uid) ||
        isAdmin()
      );

      allow delete: if false;
    }

    // ---- reviews ----
    // Public read (shown on artisan profiles). A customer can only review
    // a booking that is actually theirs and actually completed, checked
    // against the booking doc itself, not just trusted from the client.
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() &&
        request.resource.data.customerId == request.auth.uid &&
        get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.customerId == request.auth.uid &&
        get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.status == 'completed';
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ---- portfolio ----
    // An artisan's "my work" photos on their public profile. Public read,
    // an artisan can only add to or remove from their own gallery, never
    // someone else's, and a photo is never edited in place, only added or
    // deleted.
    match /portfolio/{photoId} {
      allow read: if true;
      allow create: if isSignedIn() &&
        request.resource.data.artisanId == request.auth.uid;
      allow update: if false;
      allow delete: if isSignedIn() &&
        (resource.data.artisanId == request.auth.uid || isAdmin());
    }

    // ---- chats & messages ----
    // Only the two participants can read/write a thread. A message's
    // read/create access is checked against the parent chat's participants
    // via get(), not the message doc itself, since a message has no
    // customerId/artisanId of its own.
    match /chats/{chatId} {
      allow read, update: if isSignedIn() &&
        (resource.data.customerId == request.auth.uid || resource.data.artisanId == request.auth.uid);
      allow create: if isSignedIn() &&
        (request.resource.data.customerId == request.auth.uid || request.resource.data.artisanId == request.auth.uid);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn() &&
          (get(/databases/$(database)/documents/chats/$(chatId)).data.customerId == request.auth.uid ||
           get(/databases/$(database)/documents/chats/$(chatId)).data.artisanId == request.auth.uid);
        allow create: if isSignedIn() &&
          request.resource.data.senderId == request.auth.uid &&
          (get(/databases/$(database)/documents/chats/$(chatId)).data.customerId == request.auth.uid ||
           get(/databases/$(database)/documents/chats/$(chatId)).data.artisanId == request.auth.uid);
        allow update, delete: if false;
      }
    }

    // ---- verification_requests (Become an Artisan applications) ----
    // An applicant can create and read their own request. Only admins can
    // change its status, that's what approving/rejecting means.
    match /verification_requests/{requestId} {
      allow read: if isSignedIn() &&
        (resource.data.artisanId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() &&
        request.resource.data.artisanId == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ---- payments ----
    // Written exclusively by Cloud Functions via the Admin SDK. The app
    // only ever reads a payment's status, never writes one directly.
    match /payments/{paymentId} {
      allow read: if isSignedIn() &&
        (resource.data.customerId == request.auth.uid ||
         resource.data.artisanId == request.auth.uid ||
         isAdmin());
      allow write: if false;
    }
  }
}
