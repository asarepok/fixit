rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ID/certificate photos from the Become an Artisan application. An ID
    // document is sensitive, only the person who uploaded it and an admin
    // reviewing it can read it back, nobody else, and it's never public.
    match /verification_documents/{uid}/{fileName} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if false;
    }

    // A photo a customer attaches to a review. Public, same as the review
    // itself (see firestore.rules), only the customer who's uploading it
    // can write to their own folder, and it's never editable/replaceable
    // after the fact, same as the review it belongs to.
    match /review_photos/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if false;
    }

    // An artisan's own "my work" gallery on their public profile. Public
    // read like the review photos, but unlike those, an artisan can
    // remove one of their own later, it's their portfolio, not a fixed
    // record of a past transaction.
    match /portfolio_photos/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Deny everything else by default, no other paths are in use yet.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
